# ── Project-specific: LiteVecDB runtime data ────────────────────
# Demos and ad-hoc scripts may write into local data dirs.
# Real data dirs should never be committed.
/data/
/tmp_data/
*.litevecdb/

# Demo scripts use tempfile.mkdtemp, but a stray local dir is possible.
litevecdb_*_data/
